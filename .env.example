# Copia questo file in .env e inserisci i tuoi valori da Supabase
# (Supabase Dashboard -> Project Settings -> API)
VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...la-tua-anon-key

# Base path per GitHub Pages (default /arbora/). Per dominio custom usa /
# VITE_BASE=/arbora/

# --- Google Calendar (opzionale) ---
# Abilita il collegamento del calendario: ogni utente collega il PROPRIO account
# Google e le righe con scadenza vengono sincronizzate come eventi.
# Come ottenerlo:
#   1. Google Cloud Console -> crea/usa un progetto
#   2. "API e servizi" -> abilita "Google Calendar API"
#   3. "Credenziali" -> "Crea credenziali" -> "ID client OAuth" -> tipo "Applicazione web"
#   4. In "Origini JavaScript autorizzate" aggiungi gli URL dell'app
#      (es. http://localhost:5173 e https://TUO-UTENTE.github.io)
#   5. Copia l'ID client qui sotto (finisce con .apps.googleusercontent.com)
# VITE_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
